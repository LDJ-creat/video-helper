# Backend
#Set the path to save the output data,if not set, it will save in the data directory under the root directory of the project
DATA_DIR=
LOG_LEVEL=info
#COOKIES_FILE setting:optional, recommended to upload cookies file in the web or desktop and it will automatically save in the right way
YTDLP_COOKIES_FILE=
#LLM setting:optional,recommended to set in the web or desktop,which sqlite and its proivity is higher than setting in the .env file
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_MAX_ATTEMPTS=3
LLM_TIMEOUT_S=180
# Enable background worker in local dev so jobs actually run.
WORKER_ENABLE=1

# ----------------------------
# Advanced settings (optional)
# ----------------------------
# The following settings are optional; if not set, the app uses safe defaults.

# Worker concurrency (optional).
# Default: 2
# MAX_CONCURRENT_JOBS=2

# Transcription (ASR / faster-whisper) advanced settings (optional).
# If not set:
# - device defaults to auto (use CUDA when available, otherwise CPU)
# - compute type defaults to float16 on CUDA, int8 on CPU
# - language is auto-detected by faster-whisper

# Model size or local model name. Common: tiny/base/small/medium/large-v3
# Default: base
# TRANSCRIBE_MODEL_SIZE=base

# Device selection: auto | cpu | cuda
# Default: auto
# TRANSCRIBE_DEVICE=auto

# GPU index when device=cuda (or for multi-GPU). Default: 0
# TRANSCRIBE_DEVICE_INDEX=0

# Compute type for ctranslate2.
# Leave empty to auto-select per device.
# Examples: float16 | int8 | int8_float16
# Default: (auto)
# TRANSCRIBE_COMPUTE_TYPE=

# Enable VAD (voice activity detection) to skip silence.
# Default: 1
# TRANSCRIBE_VAD_FILTER=1

# Decoding knobs. Leave empty/0 to keep faster-whisper defaults.
# TRANSCRIBE_BEAM_SIZE=
# TRANSCRIBE_BEST_OF=

# CPU performance tuning (only relevant on CPU). Leave empty to auto.
# 0 means "library default".
# TRANSCRIBE_CPU_THREADS=

# Worker threads inside faster-whisper/ctranslate2.
# Default: 1
# TRANSCRIBE_NUM_WORKERS=1

