# Backend
#Set the path to save the output data,if not set, it will save in the data directory under the root directory of the project
DATA_DIR=
LOG_LEVEL=info
#COOKIES_FILE setting:optional, recommended to upload cookies file in the web or desktop and it will automatically save in the right way
YTDLP_COOKIES_FILE=
#LLM setting:optional,recommended to set in the web or desktop,which sqlite and its proivity is higher than setting in the .env file
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_MAX_ATTEMPTS=3
LLM_TIMEOUT_S=180
# Enable background worker in local dev so jobs actually run.
WORKER_ENABLE=1

