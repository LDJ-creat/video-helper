# Backend
DATA_DIR=./data
LOG_LEVEL=info
AUTH_MODE=off
AUTH_BEARER_TOKEN=
MAX_CONCURRENT_JOBS=2
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Some Chrome/Android setups may send Origin as http://127.0.0.1 (no port).
# If you see CORS errors in Chrome but not Edge, widen allowlist, e.g.:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1
# Or use a regex:
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Frontend
# Prefer same-origin calls via Next.js rewrite proxy (avoids CORS):
# - Web browser calls /api/v1/* on http://localhost:3000
# - Next.js server proxies to API_BASE_URL
API_BASE_URL=http://127.0.0.1:8000

# Optional: direct-from-browser backend base URL. If set, browser will call the backend
# origin directly and CORS must allow the web origin.
NEXT_PUBLIC_API_BASE_URL=
