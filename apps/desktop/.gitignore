*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.local

# OS-specific
.DS_Store
Thumbs.db

# IDE / editor
.vscode/
*.suo
*.user
*.userosscache

# TypeScript
*.tsbuildinfo

# Misc
coverage/
*.tmp
*.temp
.cache/
