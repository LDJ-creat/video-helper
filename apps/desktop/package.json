{
    "name": "desktop",
    "version": "0.1.0",
    "private": true,
    "description": "Video Helper Desktop Application",
    "repository": {
        "type": "git",
        "url": "https://github.com/LDJ-creat/video-helper.git"
    },
    "main": "dist/main.js",
    "scripts": {
        "dev": "concurrently \"pnpm compile:watch\" \"electron .\"",
        "compile": "tsc -p tsconfig.json",
        "compile:watch": "tsc -p tsconfig.json --watch",
        "build": "pnpm compile && electron-builder",
        "pack": "pnpm compile && electron-builder --dir"
    },
    "dependencies": {
        "electron-is-dev": "^3.0.0",
        "electron-updater": "^6.8.3"
    },
    "devDependencies": {
        "@types/node": "^20",
        "concurrently": "^8.2.0",
        "electron": "^33.0.0",
        "electron-builder": "^25.0.0",
        "typescript": "^5.3.0"
    },
    "build": {
        "beforePack": "scripts/beforePack.cjs",
        "appId": "com.videohelper.desktop",
        "publish": [
            {
                "provider": "github",
                "owner": "LDJ-creat",
                "repo": "video-helper"
            }
        ],
        "productName": "Video Helper",
        "copyright": "Copyright © 2025 Video Helper",
        "directories": {
            "output": "release",
            "buildResources": "resources"
        },
        "files": [
            "dist/**/*"
        ],
        "extraResources": [
            {
                "from": "resources/backend",
                "to": "backend",
                "filter": [
                    "**/*"
                ]
            },
            {
                "from": "../web/.next/standalone",
                "to": "web",
                "filter": [
                    "**/*",
                    "**/.next",
                    "**/.next/**"
                ]
            },
            {
                "from": "../web/.next/server",
                "to": "web/apps/web/.next/server",
                "filter": [
                    "**/*"
                ]
            },
            {
                "from": "../web/.next",
                "to": "web/apps/web/.next",
                "filter": [
                    "BUILD_ID",
                    "trace",
                    "*.json",
                    "*.js",
                    "*.map"
                ]
            },
            {
                "from": "../web/.next/static",
                "to": "web/apps/web/.next/static",
                "filter": [
                    "**/*"
                ]
            },
            {
                "from": "../web/public",
                "to": "web/apps/web/public",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "artifactName": "Video-Helper-Setup-${version}.${ext}",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "resources/icon.ico"
        },
        "mac": {
            "artifactName": "Video-Helper-${version}-mac-${arch}.${ext}",
            "icon": "resources/icon.icns",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "linux": {
            "artifactName": "Video-Helper-${version}-linux-${arch}.${ext}",
            "icon": "resources/icon.png",
            "target": [
                "AppImage",
                "tar.gz"
            ],
            "category": "Utility"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Video Helper"
        }
    }
}
